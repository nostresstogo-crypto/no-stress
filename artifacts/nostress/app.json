{
  "expo": {
    "name": "NoStress",
    "slug": "nostress",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nostress",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#FFD700",
    "description": "NoStress — Découvrez et réservez les meilleurs événements au Togo et au Bénin : concerts, soirées, festivals, ateliers. Billetterie mobile, favoris, et notifications près de chez vous.",
    "privacy": "public",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1120"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nostresstg.app",
      "privacyPolicyUrl": "https://no-stress.net/confidentialite",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "$(PRODUCT_NAME) uses your location to show you nearby events and venues.",
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs camera access to take photos for your events or profile.",
        "NSPhotoLibraryUsageDescription": "$(PRODUCT_NAME) needs photo library access to choose a logo or profile picture.",
        "NSPhotoLibraryAddUsageDescription": "$(PRODUCT_NAME) needs permission to save your tickets to your photo library.",
        "NSUserNotificationUsageDescription": "$(PRODUCT_NAME) sends notifications about new nearby events, your favorites, and booking updates."
      }
    },
    "android": {
      "package": "com.nostresstg.app",
      "backgroundColor": "#0E1120",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0E1120"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_PHONE_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Feather.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "$(PRODUCT_NAME) needs access to your photo library to choose a profile picture or partner logo.",
          "cameraPermission": "$(PRODUCT_NAME) needs camera access to take photos for your events or profile.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "$(PRODUCT_NAME) uses your location to show you nearby events and venues."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#B5A8F0",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "b372c0cb-009a-40b0-bd7c-720947a2a462"
      },
      "apiBase": "https://api.no-stress.net/api"
    }
  }
}
